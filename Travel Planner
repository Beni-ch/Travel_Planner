# API mit Informationen zu Ländern
# kein API-Key nötig, da für alle frei zugänglich
def fetch_country_info(country_code: str):
    # country-code = Ländercode mit 2 Buchstaben, bspw. Island = "IS"
    # dieser Ländercode steht in unserer CSV als "country_code"
    """gibt die Währung, Sprache, Flaggen-Emoji, Name vom Land auf Deutsch zurück"""
    try:
        # schickt Anfrage an die API 
        # zusammengesetzte URL --> für jedes Land eine andere andere URL
        r = requests.get(
            f"https://restcountries.com/v3.1/alpha/{country_code}", timeout=5)
        if r.status_code == 200:
            d          = r.json()[0]
            # r.json gibt eine Liste zurück, auch wenn nur ein Land benötigt aufgrund des Design vom API "RestCountries"
            # da wir nicht mit einer Liste arbeiten können, wir greifen auf das erste Element der Liste zurück
            # [0] in der Liste --> das ist ein dictionary für ein bestimmtes Land
            currencies = d.get("currencies", {})
            # sucht "currencies" (=Währung) aus "d"
            # wenn das nicht existiert, stürzt das Programm nicht ab, sondern gibt einfach ein leeres Dictionary zurück
            currency   = list(currencies.values())[0]["name"] if currencies else "–"
            # list(...) --> wird in eine Liste umgewandelt
            # [0] --> holt den ersten Eintrag der Liste 
            # ["name"] ist der Key, holt den Value dazu (Name der Währung)
            # if currencies = wenn currencies nicht leer --> führt das aus
            # ansonsten (else), wenn if nicht erfüllt, wenn currencies nicht leer --> "-" als Platzhalter
            languages  = list(d.get("languages", {}).values())
            # sucht dictionary "language" aus dictionary "d"
            # gibt nur values zurück, keys sind hier nicht relevant
            # mit list() werden die value(s --> wenn das Land mehrere Sprachen) zu einer Liste umgewandelt
            
            return {
                "currency": currency,
                "language": languages[0] if languages else "–",
                # ausgegeben wird nur der erste Eintrag der Liste, damit nicht zu unübersichtlich
                # wenn leer --> Platzhalter "-"
                "flag":     d.get("flags", {}).get("emoji", ""), 
                # holt das dictionary (value) zum key "flags", falls nicht exisiert: leeres dictionary statt Absturz
                # holt value (= Flaggen-Emojie des Landes) zum key "emoji", falls nicht exisiert: leerer String statt Absturz
                "name_de":  d.get("translations", {}).get("deu", {}).get("common", ""),
                # holt das dictionary (value) zum key "translations", falls nicht exisiert: leeres dictionary statt Absturz
                # holt das dictionary (value) zum key "deu", falls nicht existiert: leeres dictionary statt Absturz
                # holt value (= deutscher Name des Landes) zum key "common", falls nicht exisiert: leerer string statt Absturz
            }
    except Exception:
        pass
        # falls irgendein Fehler auftritt, läuft das Progrmm weiter 
    return {"currency": "–", "language": "–", "flag": "", "name_de": ""}
    # gibt leere Platzhalterwerte zurück bei Fehler


