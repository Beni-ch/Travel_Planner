                st.write(f"🚗 Fahrzeit: **{ch:.1f}h** ab Zürich" if ch else "🚗 Per Auto nicht sinnvoll erreichbar")

            # CO₂ (berechnet aus Haversine-Distanz Zürich → Destination)
