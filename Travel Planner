# ──────────────────────────────────────────────────────────
# API 1: OPENWEATHERMAP – Live-Wetter abrufen
# ──────────────────────────────────────────────────────────

def fetch_weather(lat: float, lon: float):
    # lat sowie lon müssen eine Dezimalzahl bzw. float sein 
    # lat = Breitengrad 
    # lon = Längengrad
    """
    OpenWeatherMap /weather → Temperatur, Beschreibung, Luftfeuchtigkeit.
    """
    try:
        # falls etwas schief läuft, wird "except" ausgeführt --> Fehlermeldung
        # damit das Programm nicht abstürzt bei Fehler

        # fragt die API nach Wetterdaten
        # Params: Koordinaten, API-Key, Format der Antworten 
        # metric: Ausgabe in Grad Celsius
        # de: die Beschreibungen auf Deutsch
        # timeout = 8: wenn API nach 8 Sekunden nicht antwortet, wird die Anfrage abgebrochen
        # ansonsten würde das Programm ewig warten
        r = requests.get(
            "https://api.openweathermap.org/data/2.5/weather",
            params={"lat": lat, "lon": lon, "appid": OPENWEATHER_KEY,
                    "units": "metric", "lang": "de"},
            timeout=8,
        )
        # 200 = die Daten sind gut, wenn was anderes entweder falscher API-Key oder Adresse nicht gefunden
        # json = Umwandlung in Dictionary
        # aus diesem Dictionary zieht das Programm dann die Temperatur, gefühlte Temperaturm Luftfeuchtigkeit und Beschreibung 
        # capitalize() Beschreibung fängt mit einem grossen Buchstaben an
        if r.status_code == 200:
            d = r.json()
            return {
                "temp":        round(d["main"]["temp"]),
                "feels_like":  round(d["main"]["feels_like"]),
                "humidity":    d["main"]["humidity"],
                "description": d["weather"][0]["description"].capitalize(),
            }
        return {"error": f"Status {r.status_code}: {r.json().get('message', '')}"}
    except Exception as e:
        return {"error": str(e)}


