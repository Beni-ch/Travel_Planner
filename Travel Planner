# ──────────────────────────────────────────────────────────
# KNN MACHINE-LEARNING-MODELL
# ──────────────────────────────────────────────────────────
# Feature-Vektor: [live_temp, has_nature, has_culture, budget_level]
# live_temp   → OpenWeatherMap (live)
# has_nature, has_culture → destinations.csv
# budget_level→ destinations.csv

def build_feature_matrix(dest_data: list) -> np.ndarray:
    rows = []
    for d in dest_data:
        temp = d["weather"].get("temp", 15) if not d["weather"].get("error") else 15
        rows.append([
            temp,
            d["has_nature"],
            d["has_culture"],
            d["budget_level"],
        ])
    return np.array(rows, dtype=float)

def run_knn(user_vec: np.ndarray, feat_mat: np.ndarray, k: int = 10):
    all_data   = np.vstack([feat_mat, user_vec])
    all_scaled = MinMaxScaler().fit_transform(all_data)
    X, u       = all_scaled[:-1], all_scaled[-1:]
    knn        = NearestNeighbors(n_neighbors=min(k, len(X)), metric="euclidean")
    knn.fit(X)
    dist, idx  = knn.kneighbors(u)
    return idx[0], dist[0]


# ──────────────────────────────────────────────────────────
# SCORING
# ──────────────────────────────────────────────────────────
# Gewichtung: 40% Wetter | 30% Aktivitäten | 20% Sicherheit | 10% Budget
# Sicherheit: Numbeo Safety Index (0–100) → umgerechnet auf 0–10

def temp_score(dest_temp: float, user_range: str) -> float:
    low, high = TEMP_RANGES.get(user_range, (20, 25))
    return round(max(0.0, 10 - abs(dest_temp - (low + high) / 2) * 0.8), 1)

def activity_score(d: dict, reisearten: list) -> float:
    """
    Bewertet Aktivitäten-Match anhand der CSV-Flags.
    Jede Reiseart mappt auf ein oder mehrere CSV-Felder.
    """
    mapping = {
        "Städtereise":        ["has_culture"],
        "Kultur & Museen":    ["has_culture"],
        "Nightlife & Ausgang":["has_culture", "nightlife"],
        "Natur & Wandern":    ["has_nature", "has_mountains"],
        "Entspannung":        ["has_nature", "has_beach"],
        "Abenteuer & Sport":  ["has_nature", "has_mountains"],
        "Strandurlaub":       ["has_beach"],
        "Skiferien":          ["has_mountains"],
    }
    if not reisearten:
        return 7.0
    total_checks, hits = 0, 0
    for art in reisearten:
        for flag in mapping.get(art, ["has_culture"]):
            total_checks += 1
            hits += d.get(flag, 0)
    return round(min(10.0, hits / total_checks * 10), 1) if total_checks > 0 else 7.0

def budget_score_fn(hotel_price_chf: int, budget_pp: float, naechte: int) -> float:
    est = hotel_price_chf * naechte
    if   budget_pp >= est * 1.3: return 10.0
    elif budget_pp >= est:       return 8.0
    elif budget_pp >= est * 0.7: return 5.0
    return 2.0

def compute_scores(candidates, dest_data, user_temp, reisearten,
                   budget_pp, naechte, min_safety_idx) -> list:
    data_map = {d["name"]: d for d in dest_data}
    results  = []
    for name in candidates:
        d      = data_map[name]
        safety = d["safety_index"]          # Numbeo 0–100
        safety_10 = round(safety / 10, 1)  # Umrechnung auf 0–10 für Score
        if safety < min_safety_idx:
            continue
        temp = d["weather"].get("temp", 15) if not d["weather"].get("error") else 15
        t = temp_score(temp, user_temp)
        a = activity_score(d, reisearten)
        b = budget_score_fn(d["hotel_price_chf"], budget_pp, naechte)
        total = t * 0.40 + a * 0.30 + safety_10 * 0.20 + b * 0.10
        results.append({
            "name": name, "total": round(total, 2),
            "temp_score": t, "act_score": a,
            "safety_score": safety_10, "budget_score": b,
            "live_temp": temp, "safety_index": safety,
        })
    results.sort(key=lambda x: x["total"], reverse=True)
    return results


