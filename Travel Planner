    # ── KNN Machine Learning ──
    # Benutzer-Präferenzen als Feature-Vektor kodieren
    tm = {k: (v[0] + v[1]) / 2 for k, v in TEMP_RANGES.items()}
    wants_nature  = 1 if any(a in reisearten for a in
                   ["Natur & Wandern", "Entspannung", "Abenteuer & Sport",
                    "Strandurlaub", "Skiferien"]) else 0
    wants_culture = 1 if any(a in reisearten for a in
                   ["Städtereise", "Kultur & Museen", "Nightlife & Ausgang"]) else 0

    # Budget pro Person pro Nacht → Budget-Level 1/2/3
    # Einfluss auf KNN (10% Gewicht im Scoring)
    cost_pp     = budget_pp / max(naechte, 1)
    user_budget = 1 if cost_pp < 100 else (2 if cost_pp < 180 else 3)

    # KNN: findet die 10 ähnlichsten Destinationen
    user_vec   = np.array([[tm[temperatur], wants_nature, wants_culture, user_budget]])
    feat_mat   = build_feature_matrix(dest_data)
    knn_idx, _ = run_knn(user_vec, feat_mat, k=len(dest_data))  # alle ranken
    candidates = [dest_data[i]["name"] for i in knn_idx]

    # ── Transportmittel-Filter (ab Zürich) ──
    # Startpunkt: Zürich. Reisezeiten aus destinations.csv.
    # N/A = mit diesem Transportmittel nicht erreichbar → wird herausgefiltert.
    def get_hours(dest, transport_key):
        """Gibt Reisestunden zurück, None = nicht erreichbar."""
        return dest.get(transport_key)

    dest_lookup = {d["name"]: d for d in dest_data}

    if transport == "Flugzeug":
        reachable = [c for c in candidates
                     if get_hours(dest_lookup[c], "flight_hours") is not None
                     and get_hours(dest_lookup[c], "flight_hours") <= reisezeit]
    elif transport == "ÖV":
        reachable = [c for c in candidates
                     if get_hours(dest_lookup[c], "train_hours") is not None
                     and get_hours(dest_lookup[c], "train_hours") <= reisezeit]
    elif transport == "Auto":
        reachable = [c for c in candidates
                     if get_hours(dest_lookup[c], "car_hours") is not None
                     and get_hours(dest_lookup[c], "car_hours") <= reisezeit]
    else:
        reachable = candidates

    # Fallback: falls Filter zu streng (< 3 Treffer), alle nehmen
    candidates = reachable if len(reachable) >= 3 else candidates

    scored = compute_scores(candidates, dest_data, temperatur, reisearten,
                            budget_pp, naechte, min_safety_idx)
