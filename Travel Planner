# Diese Funktion wird nur aufgerufen, wenn der Nutzer auf "Hotel suchen" klickt

def fetch_hotel_data(city_name: str, check_in: str, check_out: str, adults: int):
    # Funktion bekommt vier Information: Stadtname, An- und Abreisedatum sowie Anzahl Erwachsene
    """Booking.com via RapidAPI. Nur auf Knopfdruck aufgerufen."""
    headers = {
        "X-RapidAPI-Key":  BOOKING_KEY,
        "X-RapidAPI-Host": "booking-com15.p.rapidapi.com",
    }
    # API-Key und welche API, wir nutzen wollen 
    try:
        # falls ein Fehler auftritt, springt er zum "except"
        r_dest = requests.get(
            "https://booking-com15.p.rapidapi.com/api/v1/hotels/searchDestination",
            headers=headers, params={"query": city_name}, timeout=10,
        )
        # Anfrage an API
        # fragt nach dest_id für city_name
        # nach 10 Sekunden abbrechen, wenn keine Antwort kommt
        if r_dest.status_code != 200:
            return {"error": f"Status {r_dest.status_code}: {r_dest.text[:100]}"}
            # wenn nicht gleich 200 --> Fehler
            # gibt Statuscode und Fehlermeldung zurück
            # gibt nur die ersten 100 Zeichen der Fehlermeldung zurück 
        dest_items = r_dest.json().get("data", [])
        # r_dest.json() --> Umwandlung von API-Antwort in ein dictionary
        # get(...) --> holt die Liste vonn Destinationen zum Key "data", falls "data" nicht existiert: leere Liste statt Absturz
        if not dest_items:
            return {"error": f"Keine Destination für '{city_name}' gefunden."}
            # falls die Liste leer ist, gibt es eine Fehlermeldung zurück

        dest_id, search_type = None, "CITY"
        # zwei Variabeln werden definiert
        # dest_id hat noch keinen Wert --> wird in der Schleife gesetzt
        for item in dest_items:
            # geht jeden Eintrag (dictionary) in der Liste "dest_items" durch
            if item.get("search_type", "").lower() == "city":
                # holt den Value vom Key "search_type"
                # == "city" Bedingung erfüllt, wenn es eine Stadt ist 
                # .lower(): damit Gross- und Kleinschreibung keine Rolle spielt
                dest_id = str(item["dest_id"]); search_type = "CITY"; break
                # speichert die gefundene ID als String (API erwartet String)
                # break: stoppt die Schleife, weitere Iteration unnötig
                # search_type auf "CITY" gesetzt  --> für die zweite API-Anfrage
      
        if not dest_id:
            # wird erreicht, wenn die Schleife keinen Eintrag vom Typ "city" gefunden hat
            dest_id = str(dest_items[0]["dest_id"])
            # erstes Element (= dictionary) der Liste "dest_items" (Index 0)
            # holt den Value zum Key "dest_id"
            # str(): wandelt Integer in String um, weil API einen String erwartet
            search_type = dest_items[0].get("search_type", "city").upper()
            # erstes Element (= dictionary) der Liste "dest_items" (Index 0)
            # holt den Value zum Key "search_type"
            # falls "search_type" nicht existiert, "city" als Ersatzwert
            # .upper(): wird grossgeschrieben, weil API das so erwartet


        r_h = requests.get(
            "https://booking-com15.p.rapidapi.com/api/v1/hotels/searchHotels",
            # zweite API-Anfrage: sucht jetzt echte Hotels
            headers=headers,
            params={
                "dest_id": dest_id, "search_type": search_type,
                "arrival_date": check_in, "departure_date": check_out,
                "adults": str(max(1, int(adults))), "room_qty": "1",
                "units": "metric", "temperature_unit": "c",
                "languagecode": "de", "currency_code": "CHF",
            },
            # "dest_id" und "search_type" aus erster Anfrage 
            # Anreise- und Abreisedatum, Anzahl Reisende vom Benutzer eingegeben
            # bei "adults" sichergesellt, dass min. 1 Erwachsener und in String
            # Anzahl Zimmer immer 1
            # Temperatur in Grad Celsius; Antwort auf Deutsch, Währung in Schweizer Franken
            timeout=12,
            # nach 12 Sekunden abbrechen, falls API nicht antwortet
        )
        if r_h.status_code != 200:
            return {"error": f"Status {r_h.status_code}: {r_h.text[:100]}"}
            # != 200 --> Anfrage nicht erfolgreich
            # sofort abbrechen und Fehlermeldung zurückgeben
            # nur die ersten 100 Zeichen der Fehlermeldung

        raw    = r_h.json().get("data", {})
        # API-Antwort in Dictionary umwandeln
        # holt den Value zum Key "data"
        # falls "data" nicht existiert: leeres Dicitonary als Ersatzwert
        hotels = raw.get("hotels", []) if isinstance(raw, dict) else raw
        # prüft ob "raw" ein Dictionary ist
        # API gibt manchmal ein Dictionary, manchmal direkt eine Liste zurück
        # wenn Dictionary --> holt den Value (die Liste) zum Key "hotels"
        # wenn Liste --> "raw" direkt verwenden, es sind sind bereits die Hotels
        # falls "hotels" nicht existiert: leere Liste als Ersatzwert
        if not hotels:
            return {"error": "Keine Hotels gefunden.", "hotels": []}
            # wenn hotels leer ist --> keine Hotels gefunden

        prices, hotel_list = [], []
        # zwei Listen definiert
        # "prices" --> sammelt alle Preise, um später den Durchschnitt zu berechnen
        # "hotel_list" --> sammelt alle Hotel-Dicitonaries für die Ausgabe
        for h in hotels[:20]:
            # geht die ersten 20 Hotels (= 20 Dictionaries) der Liste durch
            # damit nicht zu viele Daten
            prop  = h.get("property", {})
            # holt den Value (dictionary) zum Key "property"
            # falls "property" nicht exisitert --> leeres Dictionary als Ersatzwert
            price = prop.get("priceBreakdown", {}).get("grossPrice", {}).get("value")
              # holt das Dictionary (value) zum Key "priceBreakdown", falls nicht existiert: leeres dictionary statt Absturz
              # holt das Dictionary (value) zum Key "grossPrice", falls nicht existiert: leeres dictionary statt Absturz
              # holt Value (= Preis in CHF) zum Key "value", falls nicht existiert: None statt Absturz

            stars = int(prop.get("accuratePropertyClass", 0))
                # holt die Sternekategorie des Hotels, z.B. 4
                # int() → wandelt in Integer um
                # falls nicht existiert → 0 als Ersatzwert

            if price: prices.append(price)
                # wenn price nicht none --> hinzufügen zur Liste
            hotel_list.append({"name": prop.get("name", "Unbekannt"),
                                "stars": stars, "rating": prop.get("reviewScore", ""),
                                "price": price})
            # fügt ein Dictionary mit Name des Hotels, Sternekategorie, Bewertung und Preis hinzu
        return {
            "avg_price": round(sum(prices) / len(prices)) if prices else None,
            # Durchschnittspreis (gerundet) wird berechnent, wenn die Liste nicht leer
            # wenn Liste leer --> kein Wert
            "min_price": round(min(prices)) if prices else None,
            # holt den kleinsten Wert aus der Liste und gibt sie gerundet zurück, wenn Liste nicht leer
            # wenn Liste leer --> kein Wert
            "hotels":    hotel_list,
            # gibt die gesammelte Liste aller Hotel-Dictionaries zurück
        }
    except requests.exceptions.Timeout:
        return {"error": "Zeitüberschreitung bei Booking.com."}
         # spezieller Fehlertyp nur für Timeout
         # wird erreicht wenn die API nach 12 Sekunden nicht antwortet
         # gibt verständliche Fehlermeldung zurück

    except Exception as e:
        return {"error": str(e)}
        # fängt alle anderen Fehler ab


