            st.write(f"💰 Geschätzte Hotelkosten: **~CHF {est_total}** ({naechte} Nächte)")
            st.caption("Genaue Preise → Hotelsuche unten")

            # Reisezeit ab Zürich (aus CSV, N/A = nicht erreichbar)
