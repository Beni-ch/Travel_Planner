            "lat":          float(row["lat"]),
            "lon":          float(row["lon"]),
            # CSV speichert alle Werte als Text --> float() wandelt Text in Dezimalzahl um
            # "46.5" (Text) → 46.5 (Zahl)

            "country":      row["country_code"],
            # 2-Buchstaben-Ländercode aus CSV, z.B. "ES" für Spanien

            # Aus CSV (Numbeo Safety Index + kuratierte Aktivitätsdaten)
            "safety_index": float(row["safety_index_numbeo"]),
            # Sicherheitsindex als Dezimalzahl, z.B. 72.3

            "has_beach":    int(row["has_beach"]),
            "has_mountains":int(row["has_mountains"]),
            "has_culture":  int(row["has_culture"]),
            "has_nature":   int(row["has_nature"]),
            "nightlife":    int(row["nightlife"]),
            # CSV speichert diese Werte als Text --> int() wandelt Text in Integer um
            # 1 = vorhanden, 0 = nicht vorhanden

            "budget_level":    int(row["budget_level"]),
            # Budgetklasse, z.B. 1 = günstig, 2 = mittel, 3 = teuer

            "hotel_price_chf": int(row["hotel_price_chf"]),
            # durchschnittlicher Hotelpreis in CHF aus CSV

            # Reisezeit ab Zürich aus CSV
            # N/A = nicht sinnvoll erreichbar mit diesem Transportmittel → None
            "flight_hours": None if str(row.get("flight_hours","N/A")).strip()=="N/A"
                            else float(row["flight_hours"]) if "flight_hours" in row.index else 2.0,
            # drei Fälle:
            # 1. Wert ist "N/A" → None (z.B. Zürich ist nicht sinnvoll mit Flug erreichbar)
            # 2. Spalte existiert und hat Wert → float() wandelt Text in Zahl
            # 3. Spalte existiert nicht in CSV → 2.0 als Ersatzwert

            "train_hours":  None if str(row.get("train_hours","N/A")).strip()=="N/A"
                            else float(row["train_hours"]) if "train_hours" in row.index else None,
            # gleiche drei Fälle wie flight_hours, Ersatzwert ist None

            "car_hours":    None if str(row.get("car_hours","N/A")).strip()=="N/A"
                            else float(row["car_hours"]) if "car_hours" in row.index else None,
            # gleiche drei Fälle wie flight_hours, Ersatzwert ist None

            "sights": sights,
